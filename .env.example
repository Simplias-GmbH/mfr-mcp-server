# ────────────────────────────────────────────────────────────────────────
# mfr® MCP server configuration
# Copy this to .env and fill in values. Never commit .env.
# ────────────────────────────────────────────────────────────────────────

# Which mode to run in: "stdio" (local) or "http" (remote).
MFR_MODE=http

# Base URL of the mfr® API. Default is production; only change for testing.
MFR_BASE_URL=https://portal.mobilefieldreport.com

# ─── HTTP mode only ─────────────────────────────────────────────────────

# Public URL where this server is reachable. Used as the OAuth issuer
# and inside discovery metadata. Customers will connect their AI client
# to this URL.
PUBLIC_URL=https://mcp.simplias.com

# Port to listen on. Azure Container Apps and most platforms set this
# automatically — leave at 8080 for local dev.
PORT=8080
HOST=0.0.0.0

# AES-256 master key for sealing OAuth tokens. 64 hex characters.
# Generate with:  node scripts/generate-key.js
#
# CRITICAL: rotating this invalidates all existing customer tokens
# (they will have to re-click "Connect" in their AI client).
MFR_TOKEN_KEY=replace-me-with-output-of-generate-key

# ─── stdio mode only ────────────────────────────────────────────────────
# Only used when MFR_MODE=stdio. In HTTP mode each customer authenticates
# with their own credentials via the OAuth login page — these env vars
# are ignored.

MFR_USERNAME=
MFR_PASSWORD=
